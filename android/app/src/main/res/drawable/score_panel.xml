<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow / shadow layer -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#3308C7FF"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Background gradient -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F0020E31"
                android:endColor="#F0141D3A"
                android:angle="135"/>
            <corners android:radius="15dp"/>
        </shape>
    </item>

    <!-- Foreground glowing border -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:color="#AA8BE7FF"
                android:width="1.5dp"/>
            <corners android:radius="15dp"/>
        </shape>
    </item>

</layer-list>
