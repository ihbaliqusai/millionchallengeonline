<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#0E7490" android:endColor="#1D4ED8" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#AA8BE7FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="0" android:startColor="#16A34A" android:endColor="#0284C7" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#AAA7F3D0" />
        </shape>
    </item>
</selector>
