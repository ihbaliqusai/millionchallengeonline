<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/buttonDisabledEnd"
                android:startColor="@color/buttonDisabledStart" />
            <stroke
                android:width="2dp"
                android:color="#70B4C8D7" />
            <corners android:radius="22dp" />
            <padding
                android:left="22dp"
                android:top="10dp"
                android:right="22dp"
                android:bottom="10dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/buttonBluePressedEnd"
                android:startColor="@color/buttonBluePressedStart" />
            <stroke
                android:width="2dp"
                android:color="@color/panelStroke" />
            <corners android:radius="22dp" />
            <padding
                android:left="22dp"
                android:top="12dp"
                android:right="22dp"
                android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:centerColor="@color/colorPrimaryDark"
                android:endColor="@color/buttonBlueEnd"
                android:startColor="@color/buttonBlueStart" />
            <stroke
                android:width="2dp"
                android:color="@color/panelStroke" />
            <corners android:radius="22dp" />
            <padding
                android:left="22dp"
                android:top="10dp"
                android:right="22dp"
                android:bottom="10dp" />
        </shape>
    </item>
</selector>
