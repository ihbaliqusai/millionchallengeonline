<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33FF4D6D" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#EB061327"
                android:centerColor="#EA16172F"
                android:endColor="#D03A1020" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#88FF4D6D" />
        </shape>
    </item>
</layer-list>
