<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#338BE7FF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#EB061327"
                android:centerColor="#EA0A1C3E"
                android:endColor="#D0142D4A" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#808BE7FF" />
        </shape>
    </item>
</layer-list>
