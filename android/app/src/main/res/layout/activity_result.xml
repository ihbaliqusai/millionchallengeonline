<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/darkBlueApp"
    tools:context=".ResultActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_login"
        android:scaleType="centerCrop"
        android:alpha="0.3"
        android:contentDescription="@string/todo57" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Players row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="12dp">

                <!-- My side -->
                <TextView
                    android:id="@+id/txtMyName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="10dp"
                    android:textColor="#fff"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtMyScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtMyName"
                    android:layout_alignStart="@id/txtMyName"
                    android:textColor="@color/stepSelected"
                    android:textSize="24sp"
                    android:fontFamily="@font/baloo"
                    android:textStyle="bold" />

                <!-- Center: photos + sets -->
                <LinearLayout
                    android:id="@+id/llyPlayers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_centerHorizontal="true"
                    android:gravity="center_vertical">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgMe"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:civ_border_color="@color/player1"
                        app:civ_border_width="4dp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/txtMySets"
                        android:layout_width="36dp"
                        android:layout_height="80dp"
                        android:gravity="center"
                        android:textColor="@color/lightBlueApp"
                        android:textSize="36sp"
                        android:fontFamily="@font/baloo"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtOpponentSets"
                        android:layout_width="36dp"
                        android:layout_height="80dp"
                        android:gravity="center"
                        android:textColor="@color/lightBlueApp"
                        android:textSize="36sp"
                        android:fontFamily="@font/baloo"
                        android:textStyle="bold" />

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgOpponent"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:civ_border_color="@color/player2"
                        app:civ_border_width="4dp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <!-- Opponent side -->
                <TextView
                    android:id="@+id/txtOpponentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="10dp"
                    android:textColor="#fff"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOpponentScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtOpponentName"
                    android:layout_alignEnd="@id/txtOpponentName"
                    android:textColor="@color/stepSelected"
                    android:textSize="24sp"
                    android:fontFamily="@font/baloo"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Result text -->
            <TextView
                android:id="@+id/txtModeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:textColor="@color/lightBlueApp"
                android:textStyle="bold"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/txtModeSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:textColor="#CCFFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:textColor="#fff"
                android:textStyle="bold"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/txtScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:textColor="#fff"
                android:textStyle="bold"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/txtResultDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:textColor="#DDE7FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Opponents summary -->
            <LinearLayout
                android:id="@+id/llyOpponentsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:orientation="vertical" />

            <!-- Buttons always visible -->
            <Button
                android:id="@+id/btnNewGame"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="@string/btnNewGame"
                style="@style/button_main_menu"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnHome"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="@string/btnHome"
                style="@style/button_main_menu"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
