<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/darkBlueApp"
    tools:context=".ResultActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_login"
        android:scaleType="centerCrop"
        android:alpha="0.3"
        android:contentDescription="@string/todo57" />

    <LinearLayout
        android:id="@+id/llyPlayers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        >
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgMe"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:civ_border_color="@color/player1"
            app:civ_border_width="4dp"
            android:layout_marginEnd="10dp"
            />
        <TextView
            android:id="@+id/txtMySets"
            android:layout_width="40dp"
            android:layout_height="100dp"
            android:gravity="center"
            android:layout_marginRight="10dp"
            android:textColor="@color/lightBlueApp"
            android:textSize="40sp"
            android:fontFamily="@font/baloo"
            android:textStyle="bold"
            />
        <TextView
            android:id="@+id/txtOpponentSets"
            android:layout_width="40dp"
            android:layout_height="100dp"
            android:gravity="center"
            android:layout_marginLeft="10dp"
            android:textColor="@color/lightBlueApp"
            android:textSize="40sp"
            android:fontFamily="@font/baloo"
            android:textStyle="bold"
            />
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgOpponent"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:civ_border_color="@color/player2"
            app:civ_border_width="4dp"
            android:layout_marginLeft="10dp"
            />
    </LinearLayout>

    <TextView
        android:id="@+id/txtMyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/llyPlayers"
        android:layout_toLeftOf="@id/llyPlayers"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:textColor="#fff"
        android:textSize="24sp"
        android:textStyle="bold"
        />

    <TextView
        android:id="@+id/txtMyScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtMyName"
        android:layout_alignRight="@id/txtMyName"
        android:textColor="@color/stepSelected"
        android:textSize="26sp"
        android:fontFamily="@font/baloo"
        android:textStyle="bold"
        />

    <TextView
        android:id="@+id/txtOpponentName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/llyPlayers"
        android:layout_toRightOf="@id/llyPlayers"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="10dp"
        android:textColor="#fff"
        android:textSize="24sp"
        android:textStyle="bold"
        />

    <TextView
        android:id="@+id/txtOpponentScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtOpponentName"
        android:layout_alignLeft="@id/txtOpponentName"
        android:textColor="@color/stepSelected"
        android:textSize="26sp"
        android:fontFamily="@font/baloo"
        android:textStyle="bold"
        />

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/llyPlayers"
        android:layout_marginTop="10dp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:textSize="32sp"
        />
    <TextView
        android:id="@+id/txtScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/txtResult"
        android:layout_marginTop="5dp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:textSize="32sp"
        />
    <LinearLayout
        android:id="@+id/llyOpponentsSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtScore"
        android:layout_marginTop="14dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical" />
    <Button
        android:id="@+id/btnNewGame"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="@string/btnNewGame"
        style="@style/button_main_menu"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/llyOpponentsSummary"
        android:layout_marginTop="10dp"
        />
    <Button
        android:id="@+id/btnHome"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="@string/btnHome"
        style="@style/button_main_menu"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/btnNewGame"
        android:layout_marginTop="10dp"
        />

</RelativeLayout>
