<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/baloo"
            android:gravity="center"
            android:paddingBottom="12dp"
            android:text="الإعدادات"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/user_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <Switch
                android:id="@+id/swSound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="تشغيل الصوت"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <Switch
                android:id="@+id/swDialogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="إظهار النوافذ التوضيحية"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txtSettingsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:paddingTop="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnResetStats"
            style="@style/button_main_menu"
            android:layout_marginTop="16dp"
            android:drawableStart="@android:drawable/ic_menu_revert"
            android:drawablePadding="10dp"
            android:text="إعادة ضبط الإحصائيات" />

        <Button
            android:id="@+id/btnResetProgress"
            style="@style/button_main_menu"
            android:drawableStart="@android:drawable/ic_menu_rotate"
            android:drawablePadding="10dp"
            android:text="إعادة ضبط التقدم المحلي" />

        <Button
            android:id="@+id/btnLogout"
            style="@style/button_main_menu"
            android:drawableStart="@android:drawable/ic_lock_power_off"
            android:drawablePadding="10dp"
            android:text="@string/txtLogout" />

        <Button
            android:id="@+id/btnCloseSettings"
            style="@style/button_main_menu"
            android:drawableStart="@android:drawable/ic_media_previous"
            android:drawablePadding="10dp"
            android:text="رجوع" />

    </LinearLayout>
</ScrollView>
