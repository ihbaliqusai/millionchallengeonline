rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function publicProfileFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'username',
        'photoUrl',
        'rating',
        'trophies',
        'level',
        'createdAt',
        'lastSeenAt'
      ]);
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /friends/{friendUid} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /match_history/{matchId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /public_profiles/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid) &&
        request.resource.data.uid == uid &&
        publicProfileFieldsAreSafe();
      allow delete: if isOwner(uid);
    }

    match /matchmaking_queue/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }

    match /invitations/{invitationId} {
      allow read: if signedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow delete: if signedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
    }

    match /matches/{matchId} {
      allow read, create, update: if signedIn();
    }

    match /rooms/{roomId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.hostId == request.auth.uid &&
        request.resource.data.players[request.auth.uid] != null;

      allow update: if signedIn() && (
        // 1. Host can make any update (start, kick, score, etc.).
        resource.data.hostId == request.auth.uid ||

        // 2. Existing player can update (submit score, toggle ready, disconnect).
        resource.data.players[request.auth.uid] != null ||

        // 3. Any signed-in user may join (lobby or bot-slot replacement) as long
        //    as they are present in the resulting players map and do not change
        //    core room identity (host, mode, maxPlayers).
        (
          request.resource.data.players[request.auth.uid] != null &&
          request.resource.data.hostId == resource.data.hostId &&
          request.resource.data.mode == resource.data.mode &&
          request.resource.data.maxPlayers == resource.data.maxPlayers
        )
      );

      allow delete: if signedIn() && resource.data.hostId == request.auth.uid;
    }
  }
}
