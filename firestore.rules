rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function publicProfileFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'username',
        'photoUrl',
        'rating',
        'trophies',
        'level',
        'createdAt',
        'lastSeenAt'
      ]);
    }

    function roomMetadataUnchanged() {
      return request.resource.data.mode == resource.data.mode &&
        request.resource.data.maxPlayers == resource.data.maxPlayers &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function currentRoomParticipant() {
      return signedIn() && resource.data.players[request.auth.uid] != null;
    }

    function requestRoomParticipant() {
      return signedIn() && request.resource.data.players[request.auth.uid] != null;
    }

    function isJoiningSelf() {
      return !currentRoomParticipant() &&
        !resource.data.started &&
        requestRoomParticipant() &&
        request.resource.data.hostId == resource.data.hostId &&
        roomMetadataUnchanged() &&
        request.resource.data.players.keys().hasAll(resource.data.players.keys()) &&
        request.resource.data.players.keys().hasAny([request.auth.uid]) &&
        request.resource.data.players.keys().size() ==
          resource.data.players.keys().size() + 1;
    }

    function hostChangeAllowed() {
      return request.resource.data.hostId == resource.data.hostId ||
        request.auth.uid == resource.data.hostId;
    }

    function nonHostDoesNotKickHost() {
      return request.auth.uid == resource.data.hostId ||
        request.resource.data.players[resource.data.hostId] != null;
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /friends/{friendUid} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /match_history/{matchId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /public_profiles/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid) &&
        request.resource.data.uid == uid &&
        publicProfileFieldsAreSafe();
      allow delete: if isOwner(uid);
    }

    match /matchmaking_queue/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }

    match /invitations/{invitationId} {
      allow read: if signedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow delete: if signedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
    }

    match /matches/{matchId} {
      allow read, create, update: if signedIn();
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.hostId == request.auth.uid &&
        request.resource.data.players[request.auth.uid] != null;
      allow update: if signedIn() && (
        resource.data.hostId == request.auth.uid ||
        resource.data.players[request.auth.uid] != null ||
        (
          !resource.data.started &&
          request.resource.data.hostId == resource.data.hostId &&
          request.resource.data.players[request.auth.uid] != null
        )
      );
      allow delete: if signedIn() && resource.data.hostId == request.auth.uid;
    }
  }
}
